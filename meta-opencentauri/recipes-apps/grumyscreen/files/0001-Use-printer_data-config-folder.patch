From ab28897511dcc9de3e7c66bed6cbed9044e6275b Mon Sep 17 00:00:00 2001
From: James Turton <james.turton@gmx.com>
Date: Tue, 17 Mar 2026 20:55:46 +0100
Subject: [PATCH] Use printer_data config folder

---
 src/guppyscreen.cpp | 2 +-
 src/main.cpp        | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/guppyscreen.cpp b/src/guppyscreen.cpp
index 385abba..9dc2529 100644
--- a/src/guppyscreen.cpp
+++ b/src/guppyscreen.cpp
@@ -50,7 +50,7 @@ GuppyScreen *GuppyScreen::init(std::function<void(lv_color_t, lv_color_t)> hal_i
   set_log_level(ll);
 
   const std::string selected_theme = conf->get<std::string>("/ui/theme");
-  auto theme_config = fs::canonical("/proc/self/exe").parent_path() / "themes" / (selected_theme + ".json");
+  auto theme_config = fs::path("/usr/share/grumpyscreen") / "themes" / (selected_theme + ".json");
   ThemeConfig *theme_conf = ThemeConfig::get_instance();
   theme_conf->init(theme_config);
 
diff --git a/src/main.cpp b/src/main.cpp
index 04c6587..365b787 100644
--- a/src/main.cpp
+++ b/src/main.cpp
@@ -27,7 +27,7 @@ using namespace hv;
 
 int main(void) {
     Config *conf = Config::get_instance();
-    auto config_path = fs::canonical("/proc/self/exe").parent_path() / "grumpyscreen.cfg";
+    auto config_path = fs::path("/user-resource/printer_data/config") / "grumpyscreen.cfg";
     if (fs::exists(config_path)) {
       if (!conf->load(config_path.string())) {
           LOG_ERROR("Failed to load {}", config_path.string());
