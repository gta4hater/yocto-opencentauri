{
    "default_printer": "printer",
    "log_path": "/var/log/guppyscreen.log",
    "printers": {
        "printer": {
            "display_sleep_sec": 300,
            "moonraker_api_key": false,
            "moonraker_host": "127.0.0.1",
            "moonraker_port": 7125
        }
    },
    "thumbnail_path": "/user-resource/.thumbs",
    "wpa_supplicant": "/etc/wpa_supplicant.conf",
    "guppy_init_script": "/etc/init.d/guppyscreen"
}
